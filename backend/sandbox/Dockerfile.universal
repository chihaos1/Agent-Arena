FROM ubuntu:22.04

# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Set up Environment Paths
ENV PATH="/usr/local/go/bin:/root/.cargo/bin:/go/bin:${PATH}"
ENV GOPATH="/go"

# 1. Install System Dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    ca-certificates \
    build-essential \
    software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Node.js 18 (LTS) & Package Managers
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g yarn pnpm

# 3. Install Python 3.12
RUN add-apt-repository ppa:deadsnakes/ppa -y \
    && apt-get update \
    && apt-get install -y \
        python3.12 \
        python3.12-dev \
        python3.12-venv \
    && rm -rf /var/lib/apt/lists/*

# 4. Set Python 3.12 as default
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

# 4.5 Install pip for Python 3.12
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12

# 5. Install UV (Ultra-fast Python package installer)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/bin/uv

# 6. Install Go 1.21
RUN wget -q https://go.dev/dl/go1.21.6.linux-amd64.tar.gz \
    && tar -C /usr/local -xzf go1.21.6.linux-amd64.tar.gz \
    && rm go1.21.6.linux-amd64.tar.gz

# 7. Final System Configuration
WORKDIR /app

# 8. Verification
RUN echo "=== Verification ===" \
    && node --version \
    && npm --version \
    && yarn --version \
    && pnpm --version \
    && python --version \
    && uv --version \
    && go version

CMD ["/bin/bash"]